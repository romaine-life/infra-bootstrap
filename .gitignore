# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore bootstrap credential config files
bootstrap/*.config

# Local helm dependency artifacts from `helm dependency build`. Most wrappers
# let ArgoCD pull their subchart at render time, so their local build output
# should not be committed. The exceptions are the deliberately VENDORED
# subcharts below: their tgz is committed so argocd-repo-server renders them
# hermetically (no render-time network — see the chart's Chart.yaml).
**/charts/*.tgz
!/k8s/cloudnative-pg/charts/*.tgz
**/Chart.lock
